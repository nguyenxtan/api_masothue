PORT=3000
HTTP_TIMEOUT_MS=10000
NODE_ENV=production
DEBUG_LOOKUP=false

# Anti-bot cooldown: skip a source for N seconds after we detect a 403 / Cloudflare interstitial
SOURCE_BLOCK_COOLDOWN_SECONDS=1800

# External search fallback (used when masothue + thuvienphapluat both fail)
EXTERNAL_SEARCH_ENABLED=true
EXTERNAL_SEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=
EXTERNAL_SEARCH_TIMEOUT_MS=10000
