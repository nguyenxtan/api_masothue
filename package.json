{
  "name": "api-masothue",
  "version": "1.0.0",
  "description": "API for Vietnamese tax code address lookup",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "tsc -p tsconfig.test.json && node dist-test/tests/validateTaxCode.test.js && node dist-test/tests/slugifyVietnamese.test.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
